# PostgreSQL — use your Aiven Service URI (often includes ?sslmode=require)
# Example: postgresql://user:pass@host:port/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DEFAULTDB?sslmode=require"

JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

PORT=4000
NODE_ENV=development

# Local uploads (development)
UPLOAD_DIR="./uploads"

# Reminder emails (optional — leave empty to skip sending)
SMTP_URL=""

# Public URL of the React app (for CORS)
CLIENT_ORIGIN="http://localhost:5173"
