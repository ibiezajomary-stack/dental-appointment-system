generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DENTIST
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ConsultationStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BillingStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentProvider {
  GCASH
}

enum PaymentVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

/// Per-surface charting on odontogram (paper-style schematic).
enum ToothSurfaceStateKind {
  NONE
  CARIES
  FILLED
  CROWN
  MISSING
  WATCH
}

model User {
  id                        String               @id @default(cuid())
  email                     String               @unique
  passwordHash              String
  role                      Role
  createdAt                 DateTime             @default(now())
  patient                   Patient?
  dentist                   Dentist?
  consultationNotesAuthored ConsultationNote[]   @relation("NoteAuthor")
  toothRecordsRecorded      ToothRecord[]        @relation("ToothRecorder")
  filesUploaded             StoredFile[]         @relation("FileUploader")
  clinicTimeBlocksCreated   ClinicTimeBlock[]    @relation("ClinicTimeBlockCreator")
  paymentsVerified          AppointmentPayment[] @relation("PaymentVerifier")
}

/// Clinic-wide unavailability: no bookings may start during [startAt, endAt).
model ClinicTimeBlock {
  id          String   @id @default(cuid())
  startAt     DateTime
  endAt       DateTime
  reason      String?  @db.Text
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("ClinicTimeBlockCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([startAt])
  @@index([endAt])
}

model Patient {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  phone            String?
  dateOfBirth      DateTime?
  address          String?  @db.Text
  referredBy       String?
  emergencyContact String?
  emergencyPhone   String?
  medicalHistory   String?  @db.Text
  allergies        String?  @db.Text
  physicianName    String?
  physicianAddress String?  @db.Text
  physicianPhone   String?
  appointments     Appointment[]
  consultations    Consultation[]
  toothRecords     ToothRecord[]
  billingRecords   BillingRecord[]
  files            StoredFile[]
  dentalReport        PatientDentalReport?
  toothSurfaceStates ToothSurfaceState[]
  appointmentPayments AppointmentPayment[]
  idDocument       PatientIdDocument?
  notifications    Notification[]
  dentistNotifications DentistNotification[]
}

model Notification {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  title         String
  message       String   @db.Text
  readAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([patientId, createdAt])
  @@index([appointmentId])
}

model PatientIdDocument {
  id              String   @id @default(cuid())
  patientId        String   @unique
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  frontBlob        Bytes?
  frontMimeType    String?
  frontOriginalName String?
  backBlob         Bytes?
  backMimeType     String?
  backOriginalName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ToothSurfaceState {
  id          String                @id @default(cuid())
  patientId   String
  patient     Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothFdi    String
  /// O = occlusal/incisal center; B/L/M/D = buccal, lingual, mesial, distal
  surface     String
  state       ToothSurfaceStateKind @default(NONE)
  updatedAt   DateTime              @updatedAt
  updatedById String?

  @@unique([patientId, toothFdi, surface])
  @@index([patientId])
}

/// Clinical / consultation report aligned with paper dental record (complaint, history, exam, remarks).
model PatientDentalReport {
  id                   String   @id @default(cuid())
  patientId            String   @unique
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  presentOralComplaint String?  @db.Text
  familyHistory        String?  @db.Text
  remarks              String?  @db.Text
  /// Checklist: generalHealth, headaches, allergies, bleedingGums, heartBp, sinusTrouble, frequentColds, diabetes, selfMedication — values string or boolean as stored.
  medicalHistory       Json?
  /// faceLips, cheeks, tongue, palate, oropharynx, gingivae*, missingTeeth, malocclusion, previousDentalCare
  clinicalExamination  Json?
  updatedAt            DateTime @updatedAt
  updatedById          String?
}

model Dentist {
  id            String               @id @default(cuid())
  userId        String               @unique
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber String?
  specialty     String?
  displayName   String?
  phone         String?
  bio           String?              @db.Text
  unavailableBlocks DentistUnavailableBlock[]
  dateBlocks       DentistDateBlock[]
  paymentMethods    DentistPaymentMethod[]
  appointments      Appointment[]
  consultations     Consultation[]
  appointmentPayments AppointmentPayment[]
  notifications     DentistNotification[]
}

/// One-time dentist blocks for a specific date/time range (local time as entered; stored as timestamp).
model DentistDateBlock {
  id        String   @id @default(cuid())
  dentistId String
  dentist   Dentist  @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([dentistId, startAt])
  @@index([dentistId, endAt])
}

model DentistNotification {
  id         String   @id @default(cuid())
  dentistId  String
  dentist    Dentist  @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  patientId  String?
  patient    Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  title      String
  message    String   @db.Text
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([dentistId, createdAt])
  @@index([patientId])
}

model DentistPaymentMethod {
  id            String          @id @default(cuid())
  dentistId     String
  dentist       Dentist         @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  provider      PaymentProvider
  /// Legacy path for old uploads; new uploads use `qrBlob`.
  qrStoragePath String?
  qrBlob        Bytes?
  /// GCash account number/phone shown to patients (e.g., 09xxxxxxxxx).
  phoneNumber   String?
  mimeType      String
  originalName  String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([dentistId, provider])
  @@index([dentistId])
}

/// Recurring weekly intervals when this dentist does not accept appointments (minutes from local midnight for that weekday).
model DentistUnavailableBlock {
  id           String  @id @default(cuid())
  dentistId    String
  dentist      Dentist @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startMinutes Int
  endMinutes   Int

  @@index([dentistId])
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentistId   String
  dentist     Dentist           @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(PENDING)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  payment     AppointmentPayment?
  consultations Consultation[]
  billingRecords BillingRecord[]
  notifications Notification[]
  files        StoredFile[]

  @@index([dentistId, startAt])
}

model AppointmentPayment {
  id           String                    @id @default(cuid())
  appointmentId String                  @unique
  appointment  Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient                   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentistId    String
  dentist      Dentist                   @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  amountCents  Int
  status       PaymentVerificationStatus @default(PENDING)
  /// Legacy path for old uploads; new uploads use `proofBlob`.
  proofStoragePath String?
  proofBlob        Bytes?
  proofMimeType    String
  proofOriginalName String
  createdAt    DateTime                  @default(now())
  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?                     @relation("PaymentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([dentistId, createdAt])
  @@index([patientId, createdAt])
}

model Consultation {
  id            String               @id @default(cuid())
  patientId     String
  patient       Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dentistId     String
  dentist       Dentist              @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  status        ConsultationStatus   @default(REQUESTED)
  videoRoomId   String?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  notes         ConsultationNote[]
  files         StoredFile[]
}

model ConsultationNote {
  id                    String       @id @default(cuid())
  consultationId        String
  consultation          Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  diagnosis             String?      @db.Text
  prescribedMedication  String?      @db.Text
  notes                 String?      @db.Text
  treatmentPlan         String?      @db.Text
  createdById           String
  createdBy             User         @relation("NoteAuthor", fields: [createdById], references: [id])
  createdAt             DateTime     @default(now())
}

model ToothRecord {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothFdi     String
  condition    String?  @db.Text
  procedure    String?  @db.Text
  recordedAt   DateTime @default(now())
  recordedById String
  recordedBy   User     @relation("ToothRecorder", fields: [recordedById], references: [id])

  @@index([patientId])
}

model StoredFile {
  id             String        @id @default(cuid())
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId  String?
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  /// Legacy path for old uploads; new uploads use `blob`.
  storagePath    String?
  blob           Bytes?
  mimeType       String
  originalName   String
  sizeBytes      Int
  uploadedById   String
  uploadedBy     User          @relation("FileUploader", fields: [uploadedById], references: [id])
  createdAt      DateTime      @default(now())

  @@index([appointmentId])
}

model BillingRecord {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  amountCents   Int
  status        BillingStatus @default(PENDING)
  description   String?       @db.Text
  createdAt     DateTime      @default(now())
}
